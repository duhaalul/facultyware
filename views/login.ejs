<%- include('partials/head') %>
<body>
<div class="login-page">
  <div class="login-wrap">
    <div class="login-form-side">
      <h1>Selamat Datang</h1>
      <p style="font-size:13px;color:var(--text-3);margin-bottom:28px">Masuk ke akun Anda untuk melanjutkan</p>

      <% if (locals.error && error) { %>
      <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <form action="/login" method="POST">
        <div class="form-group">
          <label class="form-label" for="username">Username</label>
          <input type="text" name="username" id="username" class="form-input"
            placeholder="Masukkan username" required/>
        </div>
        <div class="form-group">
          <label class="form-label">Password</label>
          <input type="password" name="password" class="form-input"
            placeholder="••••••••" required/>
        </div>
        <button type="submit" class="btn btn-primary"
          style="width:100%;justify-content:center;padding:10px 14px;font-size:14px;margin-top:4px">
          Masuk
        </button>
      </form>

      <div style="margin-top:20px;font-size:12px;color:var(--text-3)">
        Dengan masuk, Anda menyetujui <a href="#" style="color:var(--accent);text-decoration:none">Ketentuan Layanan</a> dan <a href="#" style="color:var(--accent);text-decoration:none">Kebijakan Privasi</a>.
      </div>
    </div>
    <div class="login-visual">
      <div class="login-visual-content">
        <div class="login-visual-eyebrow">Sistem Informasi</div>
        <h2>Sistem Kinerja<br/>Pegawai</h2>
        <p>Kelola penugasan, pantau kinerja, dan catat logbook aktivitas harian pegawai secara terpusat.</p>
      </div>
    </div>
  </div>
</div>
</body>
</html>