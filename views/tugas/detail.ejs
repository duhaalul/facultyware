<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="page-header">
  <div class="page-header-text">
    <h2><%= tugas.title %></h2>
    <p>Detail Penugasan</p>
  </div>
  <div class="btn-group">
    <% if (user.role === 'pimpinan') { %>
      <a href="/tugas/<%= tugas.id %>/edit" class="btn btn-outline">Edit</a>
      <% if (tugas.status === 'in_progress') { %>
      <form action="/tugas/<%= tugas.id %>/selesai" method="POST">
        <button type="submit" class="btn btn-success">Tandai Selesai</button>
      </form>
      <% } %>
    <% } else { %>
      <% if (tugas.status !== 'completed') { %>
      <a href="/tugas/<%= tugas.id %>/submit" class="btn btn-primary">Kumpulkan Tugas</a>
      <% } %>
    <% } %>
  </div>
</div>

<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin-bottom:24px">
  <div class="card" style="padding:20px 24px">
    <div class="stat-label" style="margin-bottom:8px">Pegawai</div>
    <div style="font-weight:600;font-size:15px"><%= tugas.assigned_to_name || '—' %></div>
  </div>
  <div class="card" style="padding:20px 24px">
    <div class="stat-label" style="margin-bottom:8px">Status</div>
    <span class="badge <%= tugas.status==='completed' ? 'badge-success' : tugas.status==='in_progress' ? 'badge-accent' : 'badge-gray' %>">
      <%= tugas.status==='completed' ? 'Selesai' : tugas.status==='in_progress' ? 'Berjalan' : 'Assigned' %>
    </span>
  </div>
  <div class="card" style="padding:20px 24px">
    <div class="stat-label" style="margin-bottom:8px">Prioritas</div>
    <span class="badge <%= tugas.priority==='high' ? 'badge-danger' : tugas.priority==='medium' ? 'badge-warning' : 'badge-success' %>">
      <%= tugas.priority==='high' ? 'Tinggi' : tugas.priority==='medium' ? 'Sedang' : 'Rendah' %>
    </span>
  </div>
  <div class="card" style="padding:20px 24px">
    <div class="stat-label" style="margin-bottom:8px">Tenggat</div>
    <div style="font-weight:600;font-size:15px">
      <%= tugas.due_date ? new Date(tugas.due_date).toLocaleDateString('id-ID') : '—' %>
    </div>
  </div>
</div>

<% if (tugas.description) { %>
<div class="card" style="margin-bottom:20px">
  <div class="card-header"><h3>Deskripsi Tugas</h3></div>
  <div class="card-body" style="color:var(--text-2);font-size:13.5px;line-height:1.8">
    <%= tugas.description %>
  </div>
</div>
<% } %>

<div class="card" style="margin-bottom:20px">
  <div class="card-header"><h3>Kiriman Pegawai</h3></div>
  <% if (progress.length > 0) { %>
    <% progress.forEach(function(p) { %>
    <div style="padding:20px 24px;border-bottom:1px solid var(--border)">
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:16px">
        <div style="flex:1">
          <div style="font-size:12px;color:var(--text-3);margin-bottom:8px">
            <strong style="color:var(--text-2);font-size:13px"><%= p.created_by_name || '—' %></strong>
            &nbsp;·&nbsp;
            <%= new Date(p.progress_date).toLocaleDateString('id-ID') %>
          </div>
          <p style="font-size:13.5px;white-space:pre-line;color:var(--text-2);line-height:1.7;margin-bottom:12px">
            <%= p.description %>
          </p>
          <% if (p.attachment) { %>
          <a href="/uploads/<%= p.attachment %>" target="_blank"
            style="display:inline-flex;align-items:center;gap:6px;font-size:12.5px;color:var(--accent);text-decoration:none;padding:5px 10px;border:1px solid var(--accent);border-radius:6px">
            Lihat Lampiran
          </a>
          <% } %>
        </div>
        <span class="badge <%= p.status==='completed' ? 'badge-success' : 'badge-warning' %>">
          <%= p.status==='completed' ? 'Selesai' : 'Dikerjakan' %>
        </span>
      </div>
      <% if (user.role==='pimpinan' && p.status!=='completed') { %>
      <div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border)">
        <form action="/tugas/<%= tugas.id %>/revisi" method="POST" style="display:flex;gap:8px">
          <input type="hidden" name="progress_id" value="<%= p.id %>"/>
          <input type="text" name="catatan" placeholder="Tulis catatan revisi..." required
            class="form-input" style="height:38px;flex:1"/>
          <button type="submit" class="btn btn-orange">Kirim Revisi</button>
        </form>
      </div>
      <% } %>
    </div>
    <% }) %>
  <% } else { %>
  <div class="empty-state"><p>Belum ada kiriman dari pegawai.</p></div>
  <% } %>
</div>

<div style="margin-top:8px">
  <a href="<%= user.role==='pimpinan' ? '/tugas' : '/tugas/pegawai' %>" class="btn btn-outline">Kembali</a>
</div>

<%- include('../partials/footer') %>